#!/usr/bin/env python3

import asyncio
import sys
import os

# Add the backend directory to the path
sys.path.insert(0, os.path.dirname(__file__))

async def test_agents():
    try:
        print("Testing agent creation...")
        from agent_framework.factory import initialize_complete_agent_system
        
        orchestrator = await initialize_complete_agent_system()
        print("✓ Agents created successfully!")
        
        # Check if agents are registered
        print("\nRegistered agents:")
        for agent_id in sorted(orchestrator.agents.keys()):
            print(f"  - {agent_id}")
            
        # Test if the problem agents exist
        problem_agents = ['compliance_analysis', 'governance_analysis', 'gap_analysis']
        print("\nProblem agents check:")
        for agent_id in problem_agents:
            if agent_id in orchestrator.agents:
                agent_type = type(orchestrator.agents[agent_id]).__name__
                print(f"✓ Agent {agent_id} found: {agent_type}")
            else:
                print(f"✗ Agent {agent_id} NOT found")
                
        return True
        
    except Exception as e:
        print(f"✗ Error: {e}")
        import traceback
        traceback.print_exc()
        return False

if __name__ == "__main__":
    success = asyncio.run(test_agents())
    sys.exit(0 if success else 1) 